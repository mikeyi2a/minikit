{
  "name": "minikit-docs",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev --turbopack -p 3005",
    "dev:stable": "next dev -p 3005",
    "build": "next build",
    "start": "next start -p 3005",
    "sync:registry": "tsx scripts/sync-registry.ts",
    "sync:all": "tsx scripts/sync-registry.ts",
    "build:ui": "npm run build -w @mikeyi2a/minikit-ui",
    "build:cli": "npm run build -w @mikeyi2a/minikit-cli",
    "build:all": "npm run sync:all && npm run build && npm run build:ui && npm run build:cli"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.13",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-radio-group": "^1.4.0",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.1.8",
    "clsx": "^2.1.1",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3"
  }
}
